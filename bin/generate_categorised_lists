    # Categories to generate hosts files for
    CATEGORIES = {
      gaming: {
        filename: 'gaming_domains.hosts',
        title: 'Gaming Platform Domains',
        description: 'gaming platforms and communities'
      },
      developer: {
        filename: 'developer_domains.hosts',
        title: 'Developer Platform Domains',
        description: 'developer tools, package registries, and programming platforms'
      },
      music: {
        filename: 'music_domains.hosts',
        title: 'Music Platform Domains',
        description: 'music streaming and sharing platforms'
      },
      streaming: {
        filename: 'streaming_domains.hosts',
        title: 'Streaming Platform Domains',
        description: 'live streaming platforms'
      },
      forum: {
        filename: 'forum_domains.hosts',
        title: 'Forum and Q&A Domains',
        description: 'forums, Q&A platforms, and community discussion sites'
      },
      messaging: {
        filename: 'messaging_domains.hosts',
        title: 'Messaging Platform Domains',
        description: 'messaging and chat platforms'
      },
      crypto: {
        filename: 'crypto_domains.hosts',
        title: 'Cryptocurrency Platform Domains',
        description: 'cryptocurrency exchanges, forums, and NFT platforms'
      },
      blogging: {
        filename: 'blogging_domains.hosts',
        title: 'Blogging Platform Domains',
        description: 'blogging, writing, and content publishing platforms'
      },
      security: {
        filename: 'security_domains.hosts',
        title: 'Security Community Domains',
        description: 'security research, bug bounty, and hacking community platforms'
      }
    }.freeze

    def initialize(options = {})
      @category_domains = {}
      CATEGORIES.each_key { |cat| @category_domains[cat] = Set.new }
      @verbose = options[:verbose] || false
    end

    def generate_lists
      puts 'Generating categorised domain lists...'

      puts 'Adding manually curated domains...'
      add_manual_domains

      puts 'Fetching Mr.Holmes site list data...'
      fetch_mr_holmes_data

      create_lists_directory

      CATEGORIES.each do |category, info|
        generate_hosts_file(category, info)
      end

      puts ''
      puts 'Categorised lists generated successfully!'
      puts 'Files created in lists/ directory:'
      CATEGORIES.each do |category, info|
        puts "   - #{info[:filename]} (#{@category_domains[category].size} domains)"
      end
    end

    private

