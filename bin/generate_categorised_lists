    def add_domains(category, domains)
      domains.each { |domain| @category_domains[category].add(domain) }
    end

    def fetch_mr_holmes_data
      uri = URI(MR_HOLMES_SITE_LIST_URL)
      response = Net::HTTP.get_response(uri)

      unless response.code == '200'
        puts '  Could not fetch from Mr.Holmes repository, using manual domains only'
        return
      end

      begin
        data = JSON.parse(response.body)
        process_mr_holmes_site_list(data)
      rescue JSON::ParserError => e
        puts "  Error parsing Mr.Holmes site list: #{e.message}"
      end

      @category_domains.each do |category, domains|
        puts "  #{category}: #{domains.size} domains" if @verbose
      end
    end

    def process_mr_holmes_site_list(data)
      sites = data.is_a?(Array) ? data.first : data
      return unless sites.is_a?(Hash)

      sites.each do |_key, site_info|
        next unless site_info.is_a?(Hash)

        tags = site_info['Tag']
        next unless tags.is_a?(Array)

        main_domain = site_info['main']
        next unless main_domain

        domain = clean_mr_holmes_domain(main_domain)
        next unless domain && valid_domain?(domain)

        # Determine categories from tags (only include categories we have sets for)
        categories = tags.flat_map { |tag| TAG_TO_CATEGORY[tag.downcase.strip] }.compact.uniq
        categories = categories.select { |cat| @category_domains.key?(cat) }

        categories.each do |category|
          @category_domains[category].add(domain.downcase)

          # Also extract domains from user URLs
          extract_domain_to_category(site_info['user'], category)
          extract_domain_to_category(site_info['user2'], category)
          extract_domain_to_category(site_info['Scrapable_url'], category) if site_info['Scrapable_url']
        end
      end
    end

    def extract_domain_to_category(url, category)
      return unless url

      match = url.match(%r{https?://(?:www\.)?([a-zA-Z0-9.-]+\.[a-zA-Z]{2,})})
      return unless match

      domain = match[1].downcase
      @category_domains[category].add(domain) if valid_domain?(domain)
    end

    def clean_mr_holmes_domain(domain)
      return nil unless domain

      cleaned = domain.strip
      cleaned = cleaned.sub(%r{^https?://}, '')
      cleaned = cleaned.sub(%r{/+$}, '')
      cleaned = cleaned.sub(/^www\./, '')
      cleaned
    end

    def valid_domain?(domain)
      return false unless domain
      return false if domain.length < 4
      return false unless domain.match?(/^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/)
      return false if domain.include?('example.') || domain.include?('test.')
      return false if domain.include?('localhost')
      return false if domain.end_with?('.html') || domain.end_with?('.htm')
      return false if domain.start_with?('api.') && !domain.include?('mojang')

      true
    end

    def create_lists_directory
      FileUtils.mkdir_p('lists')
    end

    def generate_hosts_file(category, info)
      hosts_file_path = "lists/#{info[:filename]}"

      File.open(hosts_file_path, 'w') do |file|
        write_hosts_header(file, info)

        @category_domains[category].sort.each do |domain|
          file.puts "0.0.0.0 #{domain}"
          file.puts "0.0.0.0 www.#{domain}" unless domain.start_with?('www.')
        end
      end
    end

    def write_hosts_header(file, info)
      file.puts "# #{info[:title]} - PiHole Compatible Hosts File"
      file.puts "# Generated on: #{Time.now.strftime('%Y-%m-%d %H:%M:%S UTC')}"
      file.puts '# Sources:'
      file.puts '#   - Mr.Holmes OSINT tool (https://github.com/Lucksi/Mr.Holmes)'
      file.puts '#   - Manually curated domain lists'
      file.puts "# Purpose: Identify and categorize #{info[:description]}"
      file.puts '# Format: 0.0.0.0 domain.com'
      file.puts '#'
      file.puts ''
    end
  end
end

# Run the generator if this file is executed directly
if __FILE__ == $0
  options = { verbose: false }

  OptionParser.new do |opts|
    opts.banner = "Usage: #{$0} [options]"
    opts.separator ''
    opts.separator 'Generate categorised domain lists from Mr.Holmes OSINT tool and curated sources'
    opts.separator ''
    opts.separator 'Categories generated:'
    CategorisedListGenerator::SiteParser::CATEGORIES.each do |category, info|
      opts.separator "  - #{category}: #{info[:description]}"
    end
    opts.separator ''

    opts.on('-v', '--verbose', 'Verbose output') do
      options[:verbose] = true
    end

    opts.on('-h', '--help', 'Show this help message') do
      puts opts
      exit
    end
  end.parse!

  generator = CategorisedListGenerator::SiteParser.new(options)
  generator.generate_lists
end
